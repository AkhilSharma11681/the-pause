# Copy this file to .env.local and fill in your values

# Resend — for patient confirmation emails
# Get your key at: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google Sheets webhook — to log bookings to a spreadsheet
# How to set up:
# 1. Open Google Sheets → Extensions → Apps Script
# 2. Paste the webhook script from: https://github.com/dwyl/learn-to-send-email-via-google-script-html-no-server
# 3. Deploy as Web App → copy the URL here
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
